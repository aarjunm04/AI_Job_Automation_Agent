# =============================================================================
# java.env.template — AI Job Application Agent
# Copy this file to ~/java.env and fill in all values.
# NEVER commit ~/java.env to git. This template is safe to commit.
# =============================================================================

# ---------------------------------------------------------------------------
# LLM APIs
# ---------------------------------------------------------------------------
GROQ_API_KEY=
CEREBRAS_API_KEY=
XAI_API_KEY=
PERPLEXITY_API_KEY=
SAMBANOVA_API_KEY=
NVIDIA_NIM_API_KEY=
GEMINI_API_KEY=
AGENTOPS_API_KEY=

# ---------------------------------------------------------------------------
# Database — PostgreSQL
# ---------------------------------------------------------------------------
SUPABASE_URL=
SUPABASE_KEY=
LOCAL_POSTGRES_USER=postgres
LOCAL_POSTGRES_PASSWORD=
LOCAL_POSTGRES_DB=ai_job_db
# Docker-internal URL (used by agentrunner / rag-server inside ai_job_network)
LOCAL_POSTGRES_URL=postgresql://postgres:YOUR_PASSWORD_HERE@postgres:5432/ai_job_db
ACTIVE_DB=local

# ---------------------------------------------------------------------------
# Database — Redis
# ---------------------------------------------------------------------------
# Docker-internal URL (switch to redis://localhost:6379 for local dev outside Docker)
REDIS_URL=redis://redis:6379/0

# ---------------------------------------------------------------------------
# Database — ChromaDB
# ---------------------------------------------------------------------------
CHROMADB_HOST=chromadb
CHROMADB_PORT=8000

# ---------------------------------------------------------------------------
# RAG Server
# ---------------------------------------------------------------------------
RAG_SERVER_URL=http://rag-server:8090

# ---------------------------------------------------------------------------
# Scraping — SerpAPI keys (4-key round-robin rotation)
# ---------------------------------------------------------------------------
SERPAPI_API_KEY_1=
SERPAPI_API_KEY_2=
SERPAPI_API_KEY_3=
SERPAPI_API_KEY_4=

# Phase 2 only
JOOBLE_API_KEY=

# ---------------------------------------------------------------------------
# Scraping — Webshare proxies (20 total, 2 accounts x 10)
# ---------------------------------------------------------------------------
WEBSHARE_PROXY_LIST=
WEBSHARE_USERNAME_1=
WEBSHARE_PASSWORD_1=
WEBSHARE_USERNAME_2=
WEBSHARE_PASSWORD_2=

# ---------------------------------------------------------------------------
# Notion
# ---------------------------------------------------------------------------
NOTION_API_KEY=
NOTION_APPLICATIONS_DB_ID=
NOTION_JOB_TRACKER_DB_ID=

# ---------------------------------------------------------------------------
# System Config
# ---------------------------------------------------------------------------
RUN_SCHEDULE=0 6 1,4,6 * *
XAI_COST_CAP_PER_RUN=0.38
TOTAL_MONTHLY_BUDGET=10.00
JOBS_PER_RUN_TARGET=150
JOBS_PER_RUN_MINIMUM=100
MAX_PLAYWRIGHT_SESSIONS=5
AUTO_APPLY_ENABLED=true
RESUME_DIR=/app/resumes
DEFAULT_RESUME=default_resume.pdf
LOG_LEVEL=INFO
FASTAPI_PORT=8000
FASTAPI_HOST=0.0.0.0
DRY_RUN=false

# ---------------------------------------------------------------------------
# User Profile (used by /autofill endpoint and Apply Agent)
# ---------------------------------------------------------------------------
USERNAME=
USER_EMAIL=
USER_PHONE=
USER_LINKEDIN_URL=
USER_PORTFOLIO_URL=
USER_LOCATION=
USER_ACCEPTED_JOB_TYPES=full-time,contract
USER_ACCEPTED_LOCATIONS=Remote,India
USER_YEARS_EXPERIENCE=
